# Supabase — copy real values from Supabase Dashboard → Connect dialog
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json

# Admin allowlist — comma-separated emails that can access the admin dashboard.
# In production, if this is empty ALL logins are denied.
# In development, if this is empty a warning is logged and all emails are allowed.
ADMIN_ALLOWED_EMAILS=you@example.com,co-founder@example.com
